        "jest": "^29.7.0",
        "eslint": "^8.56.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [
        "colab",
        "google-colab",
        "orchestrator",
        "api",
        "backend",
        "render",
        "express"
    ],
    "author": "Kushal Kumar J",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/kushalkumarj2006/repochat"
