{
    "name": "repochat",
    "version": "3.2.0",
    "description": "Google Colab Orchestrator - API-Only Backend for 3 Frontend Apps",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "test": "jest",
        "lint": "eslint server.js",
        "clean": "rm -rf node_modules package-lock.json && npm install",
        "doctor": "node -e \"console.log('Node:', process.version, 'Memory:', Math.round(process.memoryUsage().rss / 1024 / 1024), 'MB')\""
